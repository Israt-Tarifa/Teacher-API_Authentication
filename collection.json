    {
      "name": "Auth",
      "item": [
        {
          "name": "Log in",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\",function(){",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "let jsonData=pm.response.json()",
                  "let token=jsonData.authToken;",
                  "pm.collectionVariables.set(\"token\", token);",
                  "pm.environment.set(\"token\", token);",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"admin\",\r\n    \"password\": \"password123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Teachers CRUD",
      "item": [
        {
          "name": "Create Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "let res = pm.response.json();\r",
                  "pm.environment.set(\"teacherId\", res.teacherId); \r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function getRandomInt(min, max) {\r",
                  "    return Math.floor(Math.random() * (max - min + 1)) + min;\r",
                  "}\r",
                  "\r",
                  "let randomTeacherId = getRandomInt(1000, 9999);\r",
                  "pm.environment.set(\"teacherId\", randomTeacherId);\r",
                  "\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"test{{$randomFirstName}}\",\r\n  \"email\": \"{{$randomEmail}}\",\r\n  \"department\": \"CSE\",\r\n  \"teacherId\": {{teacherId}},\r\n  \"designation\": \"Associate Professor\"\r\n}\r\n\r\n",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/teacher",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "teacher"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get all Teachers",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Each teacher has required fields\", function () {\r",
                  "    let teachers = pm.response.json();\r",
                  "    teachers.forEach(teacher => {\r",
                  "        pm.expect(teacher).to.have.property(\"name\");\r",
                  "        pm.expect(teacher).to.have.property(\"email\");\r",
                  "        pm.expect(teacher).to.have.property(\"department\");\r",
                  "        pm.expect(teacher).to.have.property(\"teacherId\");\r",
                  "        pm.expect(teacher).to.have.property(\"designation\");\r",
                  "    });\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/teacher",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "teacher"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Teacher by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "let res = pm.response.json();\r",
                  "let teacherId = parseInt(pm.environment.get(\"teacherId\"));\r",
                  "\r",
                  "pm.test(\"Created teacher exists in response\", function () {\r",
                  "    pm.expect(res.teacherId).to.eql(teacherId);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
